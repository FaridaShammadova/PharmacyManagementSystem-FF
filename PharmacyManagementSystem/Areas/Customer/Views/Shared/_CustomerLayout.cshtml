@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - PharmaShop</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
            :root {
                --light-green: #eaf6ed;
                --primary-green: #4b936c;
                --mint-green: #71b894;
                --dark-text: #2c3e35;
                --border-color: #daede1;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: #f4f9f6;
                color: var(--dark-text);
                display: flex;
                flex-direction: column;
                min-height: 100vh;
            }

            .navbar {
                background: #ffffff;
                border-bottom: 2px solid var(--light-green);
                box-shadow: 0 2px 15px rgba(75, 147, 108, 0.04);
            }

            .navbar-brand {
                font-weight: 700;
                color: var(--primary-green) !important;
                font-size: 1.3rem;
            }

            .nav-link-custom {
                color: var(--dark-text) !important;
                font-weight: 600;
                transition: all 0.2s;
                border-radius: 8px;
                padding: 8px 14px !important;
            }

                .nav-link-custom:hover {
                    color: var(--primary-green) !important;
                    background-color: var(--light-green);
                }

            .nav-search-form {
                max-width: 380px;
                width: 100%;
            }

            .nav-search-input {
                border: 2px solid var(--light-green);
                background-color: #fafdfb;
                border-radius: 20px 0 0 20px;
                padding: 7px 16px;
                font-size: 0.9rem;
                font-weight: 500;
                transition: all 0.2s;
            }

                .nav-search-input:focus {
                    border-color: var(--primary-green);
                    background-color: #ffffff;
                    box-shadow: none;
                }

            .btn-nav-search {
                border: 2px solid var(--light-green);
                border-left: none;
                background-color: var(--light-green);
                color: var(--primary-green);
                border-radius: 0 20px 20px 0;
                padding: 7px 16px;
                transition: all 0.2s;
            }

            .nav-search-form:focus-within .btn-nav-search {
                background-color: var(--primary-green);
                color: white;
                border-color: var(--primary-green);
            }

            .hero {
                background: linear-gradient(135deg, #a3d9b9 0%, var(--primary-green) 100%);
                color: white;
                padding: 60px 20px;
                border-radius: 0 0 30px 30px;
                box-shadow: 0 10px 25px rgba(75, 147, 108, 0.1);
            }

                .hero h1 {
                    font-size: 2.6rem;
                    font-weight: 800;
                    letter-spacing: -0.5px;
                }

            .content {
                padding: 40px 15px;
                flex-grow: 1;
            }

            footer {
                padding: 24px;
                text-align: center;
                background: #ffffff;
                color: #71877c;
                font-weight: 500;
                font-size: 0.9rem;
                margin-top: auto;
                border-top: 2px solid var(--light-green);
            }

            .btn-nav-action {
                border: 2px solid var(--light-green);
                background-color: var(--light-green);
                color: var(--primary-green);
                font-weight: 600;
                transition: all 0.2s;
                display: flex;
                align-items: center;
                gap: 6px;
            }

                .btn-nav-action:hover {
                    border-color: var(--primary-green);
                    background-color: white;
                    color: var(--primary-green);
                }

            .user-dropdown-btn {
                background-color: #ffffff;
                border: 2px solid var(--light-green);
                color: var(--primary-green);
                width: 42px;
                height: 42px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 50%;
                transition: all 0.2s;
            }

                .user-dropdown-btn:hover, .user-dropdown-btn:focus {
                    background-color: var(--primary-green);
                    color: white;
                    border-color: var(--primary-green);
                }

            .dropdown-menu-custom {
                border: 1px solid var(--border-color);
                box-shadow: 0 10px 25px rgba(75, 147, 108, 0.08);
                border-radius: 12px;
                padding: 8px;
            }

            .dropdown-item-custom {
                border-radius: 8px;
                padding: 10px 16px;
                font-weight: 500;
                color: var(--dark-text);
                display: flex;
                align-items: center;
                gap: 8px;
                transition: all 0.2s;
            }

                .dropdown-item-custom:hover {
                    background-color: var(--light-green);
                    color: var(--primary-green);
                }

            .btn-logout-link {
                width: 100%;
                text-align: left;
                background: none;
                border: none;
                color: #dc2626 !important;
            }

                .btn-logout-link:hover {
                    background-color: #fff0f0;
                }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg px-4 py-3 navbar-light sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-area="Customer" asp-controller="Dashboard" asp-action="Index">
                <span>💊 PharmaShop</span>
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#customerNavbar">
                <span class="bi bi-list fs-3 text-success"></span>
            </button>

            <div class="collapse navbar-collapse" id="customerNavbar">
                <div class="navbar-nav mb-2 mb-lg-0 ms-lg-2 gap-1">
                    <a class="nav-link-custom nav-link" asp-area="Customer" asp-controller="Dashboard" asp-action="Index">
                        Panel
                    </a>
                    <a class="nav-link-custom nav-link" asp-area="Customer" asp-controller="Medicine" asp-action="Index">
                        Dərmanlar
                    </a>
                    <a class="nav-link-custom nav-link" asp-area="Customer" asp-controller="Order" asp-action="Index">
                        Sifarişlərim
                    </a>
                </div>

                <form method="get" asp-area="Customer" asp-controller="Medicine" asp-action="Index" class="nav-search-form d-flex mx-auto my-3 my-lg-0">
                    <input type="text" name="search" class="form-control nav-search-input" placeholder="Dərman və ya tibbi məhsul axtar..." aria-label="Search">
                    <button class="btn btn-nav-search" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <div class="d-flex align-items-center gap-2">

                    <a class="btn btn-nav-action rounded-pill px-3 py-2" asp-area="Customer" asp-controller="Wishlist" asp-action="Index" title="Saxlanılanlar">
                        <i class="bi bi-heart"></i>
                        <span class="d-none d-xl-inline">Saxlanılanlar</span>
                    </a>

                    <a class="btn btn-nav-action rounded-pill px-3 py-2 me-lg-2" asp-area="Customer" asp-controller="Cart" asp-action="Index" title="Səbətim">
                        <i class="bi bi-basket"></i>
                        <span class="d-none d-xl-inline">Səbətim</span>
                    </a>

                    <div class="dropdown">
                        <button class="user-dropdown-btn" type="button" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-fill fs-5"></i>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-custom mt-2" aria-labelledby="userMenuDropdown">
                            <li>
                                <a class="dropdown-item dropdown-item-custom" asp-area="Customer" asp-controller="Profile" asp-action="Index">
                                    <i class="bi bi-gear"></i> Hesab Parametrləri
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" style="opacity: 0.08;"></li>
                            <li>
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item dropdown-item-custom btn-logout-link">
                                        <i class="bi bi-box-arrow-right"></i> Çıxış Et
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </nav>

    @if (ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index")
    {
        <div class="hero text-center">
            <div class="container">
                <h1>Find Your Medicine Easily</h1>
                <p class="fs-5 opacity-90 mt-2">Order and get your medicine quickly</p>
            </div>
        </div>
    }

    <div class="content container">
        @RenderBody()
    </div>

    <footer>
        <div class="container">
            © @DateTime.Now.Year PharmaShop - All rights reserved
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>