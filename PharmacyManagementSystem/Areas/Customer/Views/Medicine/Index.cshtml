@model List<MedicineViewModel>

@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Dərmanlar";
}

<style>
    :root {
        --light-green: #eaf6ed;
        --primary-green: #4b936c;
        --dark-text: #2c3e35;
        --border-color: #daede1;
    }

    .med-shop-card {
        background: #ffffff;
        border: 1px solid var(--border-color);
        border-radius: 18px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
    }

        .med-shop-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary-green);
            box-shadow: 0 10px 25px rgba(75, 147, 108, 0.06);
        }

    .med-img-wrapper {
        height: 160px;
        background-color: #f8fbf9;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-green);
        border-bottom: 1px solid #f0f7f3;
        transition: all 0.2s;
    }

    .med-shop-card:hover .med-img-wrapper {
        background-color: var(--light-green);
    }

    .med-title {
        color: var(--dark-text);
        font-weight: 700;
        font-size: 1.05rem;
    }

    .med-desc {
        color: #71877c;
        font-size: 0.85rem;
        height: 38px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .med-price {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--dark-text);
    }

    .action-buttons-group {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-action-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        transition: all 0.2s ease;
        text-decoration: none;
        font-size: 1.05rem;
    }

    .btn-add-cart-icon {
        background-color: var(--light-green);
        color: var(--primary-green);
    }

        .btn-add-cart-icon:hover {
            background-color: var(--primary-green);
            color: #ffffff;
            transform: scale(1.05);
        }

    .btn-wishlist-icon {
        background-color: #fdf2f2;
        color: #de3e3e;
    }

        .btn-wishlist-icon:hover {
            background-color: #de3e3e;
            color: #ffffff;
            transform: scale(1.05);
        }

    .btn-view-icon {
        background-color: #f1f5f9;
        color: #64748b;
    }

        .btn-view-icon:hover {
            background-color: #64748b;
            color: #ffffff;
            transform: scale(1.05);
        }

    .active-wishlist {
        background-color: #de3e3e !important;
        color: white !important;
    }
</style>

<div class="container mt-2">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h4 class="fw-bold mb-1" style="color: var(--dark-text);">Dərman Kataloqu</h4>
            <p class="text-muted small mb-0">Sertifikatlı, yüksək keyfiyyətli və 100% orijinal tibbi məhsullar</p>
        </div>
        <span class="badge bg-white text-success border px-3 py-2 rounded-pill fw-semibold">
            Toplam: @Model.Count ədəd
        </span>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="med-shop-card h-100">

                        <div>
                            <div class="med-img-wrapper">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" style="width: 100%; height: 100%; object-fit: cover" />
                                }
                                else
                                {
                                    <i class="bi bi-capsule-pill fs-1"></i>
                                }
                            </div>

                            <div class="p-3">
                                <h6 class="med-title text-truncate mb-1" title="@item.Name">
                                    @item.Name
                                </h6>
                                <p class="med-desc mb-0" title="@item.Description">
                                    @(string.IsNullOrEmpty(item.Description) ? "Bu məhsul haqqında ətraflı məlumat daxil edilməyib." : item.Description)
                                </p>
                            </div>
                        </div>

                        <div class="p-3 pt-0">
                            <hr class="mt-0 mb-3" style="opacity: 0.05;">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="med-price">
                                    @item.Price.ToString("0.00") <small class="fs-6 fw-normal">₼</small>
                                </span>

                                <div class="action-buttons-group">

                                    <form asp-area="Customer"
                                          asp-controller="Cart"
                                          asp-action="Add"
                                          method="post">

                                        <input type="hidden" name="medicineId" value="@item.Id" />

                                        <button type="submit"
                                                class="btn-action-icon btn-add-cart-icon"
                                                title="Səbətə əlavə et">
                                            <i class="bi bi-bag-plus"></i>
                                        </button>
                                    </form>

                                    <form asp-area="Customer"
                                          asp-controller="Wishlist"
                                          asp-action="Add"
                                          method="post">

                                        <input type="hidden" name="medicineId" value="@item.Id" />

                                        <button type="submit"
                                                class="btn-action-icon btn-wishlist-icon @(item.IsInWishlist ? "active-wishlist" : "")"
                                                title="Saxla">
                                            <i class="bi @(item.IsInWishlist ? "bi-heart-fill" : "bi-heart")"></i>
                                        </button>

                                    </form>

                                    <a asp-area="Customer"
                                       asp-controller="Medicine"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn-action-icon btn-view-icon"
                                       title="Ətraflı bax">
                                        <i class="bi bi-arrow-right-short" style="font-size: 1.3rem;"></i>
                                    </a>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-capsule-pill fs-1 text-muted d-block mb-2" style="opacity: 0.5;"></i>
                <h5 class="text-muted fw-bold">Axtardığınız məhsul tapılmadı</h5>
                <small class="text-muted">Kataloqumuz tezliklə yenilənəcək. Zəhmət olmasa bir az sonra yenidən yoxlayın.</small>
            </div>
        }
    </div>
</div>
