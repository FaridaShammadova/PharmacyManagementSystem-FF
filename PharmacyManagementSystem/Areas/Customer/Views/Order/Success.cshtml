@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Uğurlu sifariş";
}

<div class="container mt-5">

    <div class="text-center bg-white p-5 rounded-4 shadow-sm">

        <i class="bi bi-check-circle-fill text-success"
           style="font-size:70px;"></i>

        <h2 class="fw-bold mt-3">
            Sifariş uğurla yaradıldı
        </h2>

        <p class="text-muted">
            Sifarişiniz qəbul edildi və emala göndərildi.
        </p>

        <a asp-area="Customer"
           asp-controller="Medicine"
           asp-action="Index"
           class="btn btn-success mt-3 rounded-3 px-4">
            Alış-verişə davam et
        </a>

    </div>

</div>