@{
    var fullName = User.FindFirstValue(ClaimTypes.Name);
    var role = User.FindFirstValue(ClaimTypes.Role);
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PharmaSoft - Satıcı Paneli</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
            :root {
                --sidebar-width: 270px;
                --primary-green: #4b936c;
                --dark-green: #1e3a2b;
                --light-green: #f4f8f6;
                --accent-green: #16a34a;
                --border-color: #eef2f0;
            }

            body {
                background-color: #f8faf9;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                color: #334139;
            }

            .sidebar {
                width: var(--sidebar-width);
                height: 100vh;
                position: fixed;
                top: 0;
                left: 0;
                background-color: #ffffff;
                border-right: 1px solid var(--border-color);
                z-index: 1000;
                box-shadow: 4px 0 24px rgba(0, 0, 0, 0.015);
            }

            .main-content {
                margin-left: var(--sidebar-width);
                padding: 2rem;
                min-height: 100vh;
                background-color: #f8faf9;
            }

            .brand-wrapper {
                padding: 10px 5px;
            }

            .nav-link-custom {
                color: #55635a;
                padding: 12px 16px;
                border-radius: 10px;
                margin: 4px 0;
                transition: all 0.2s ease;
                font-weight: 600;
                font-size: 0.88rem;
                display: flex;
                align-items: center;
                text-decoration: none;
                position: relative;
            }

                .nav-link-custom i {
                    margin-right: 12px;
                    font-size: 1.1rem;
                    transition: transform 0.2s ease;
                }

                .nav-link-custom:hover {
                    background-color: var(--light-green);
                    color: var(--primary-green) !important;
                }

                    .nav-link-custom:hover i {
                        transform: scale(1.08);
                    }

                .nav-link-custom.active {
                    background-color: var(--light-green);
                    color: var(--primary-green) !important;
                }

                    .nav-link-custom.active::before {
                        content: '';
                        position: absolute;
                        left: 0;
                        top: 25%;
                        height: 50%;
                        width: 4px;
                        background-color: var(--primary-green);
                        border-radius: 0 4px 4px 0;
                    }

            .text-green-primary {
                color: var(--primary-green);
            }

            .text-dark-green {
                color: var(--dark-green);
            }

            .top-header {
                background: #ffffff;
                border-bottom: 1px solid var(--border-color);
                padding: 1.2rem 2rem;
                margin: -2rem -2rem 2rem -2rem;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.01);
            }

            .profile-icon {
                background-color: #eaf6ed;
                color: var(--primary-green);
                width: 38px;
                height: 38px;
                transition: all 0.2s ease;
                border: 1px solid #daede1;
            }

            .dropdown-toggle-custom:hover .profile-icon {
                background-color: var(--primary-green);
                color: #ffffff;
            }

            .dropdown-menu-custom {
                border: 1px solid var(--border-color) !important;
                box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important;
                border-radius: 12px !important;
                padding: 8px !important;
            }

            .dropdown-item-custom {
                padding: 10px 14px !important;
                border-radius: 8px !important;
                font-size: 0.85rem !important;
                font-weight: 500 !important;
                color: #434d47 !important;
            }

                .dropdown-item-custom:hover {
                    background-color: var(--light-green) !important;
                    color: var(--primary-green) !important;
                }

            .badge-soft-danger {
                background-color: #fef2f2;
                color: #dc2626;
                font-weight: 700;
                font-size: 0.75rem;
                padding: 4px 8px !important;
            }

            .link-danger-custom {
                color: #dc2626;
            }

                .link-danger-custom:hover {
                    background-color: #fef2f2;
                    color: #b91c1c !important;
                }

            .sidebar-footer {
                margin-top: auto;
                padding: 16px 12px;
                border-top: 1px solid rgba(255,255,255,0.05);
            }

            .logout-btn {
                width: 100%;
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 16px;
                border: none;
                background: transparent;
                color: #fca5a5;
                font-size: 0.88rem;
                font-weight: 600;
                border-radius: 10px;
                transition: 0.2s;
                cursor: pointer;
            }

                .logout-btn:hover {
                    background: rgba(239, 68, 68, 0.1);
                    color: #ef4444;
                    padding-left: 20px;
                }
    </style>
</head>
<body>

    <div class="sidebar d-flex flex-column p-3 justify-content-between">
        <div>
            <div class="brand-wrapper mb-4 mt-2">
                <a href="#" class="d-flex align-items-center text-decoration-none gap-2">
                    <div class="d-flex align-items-center justify-content-center rounded-3" style="background-color: #eaf6ed; width: 40px; height: 40px; border: 1px solid #daede1;">
                        <i class="bi bi-capsule text-green-primary fs-4"></i>
                    </div>
                    <span class="fs-4 fw-bold text-dark-green tracking-tight" style="letter-spacing: -0.5px;">Pharma<span class="text-green-primary">Soft</span></span>
                </a>
            </div>

            <div class="nav-container">
                <p class="text-uppercase text-muted fw-bold mb-2 ps-2" style="font-size: 0.68rem; letter-spacing: 0.8px;">Əsas Menyu</p>
                <nav class="nav flex-column">
                    <a href="/Seller/Dashboard/Index" class="nav-link-custom active">
                        <i class="bi bi-cpu"></i> Ana Səhifə
                    </a>
                    
                    <a href="/Seller/POS/Index" class="nav-link-custom">
                        <i class="bi bi-house"></i> Kassa (POS)
                    </a>

                    <a href="/Seller/Stock/Index" class="nav-link-custom">
                        <i class="bi bi-box-seam"></i> Stok İdarəetməsi
                    </a>

                    <a href="/Seller/Order/Index" class="nav-link-custom justify-content-between">
                        <span class="d-flex align-items-center">
                            <i class="bi bi-cart3"></i> Onlayn Sifarişlər
                        </span>

                        <span class="badge rounded-pill bg-danger">
                            @ViewBag.NewOrdersCount
                        </span>
                    </a>

                    <a href="/Seller/Alert" class="nav-link-custom link-danger-custom mt-2">
                        <i class="bi bi-exclamation-triangle"></i> Kritik Bildirişlər
                    </a>
                </nav>
            </div>
        </div>

        <div class="dropdown border-top pt-3" style="border-color: var(--border-color) !important;">
            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark dropdown-toggle-custom" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                <div class="profile-icon rounded-circle d-flex align-items-center justify-content-center me-2 shadow-sm">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div class="d-flex flex-column">
                    <span class="fw-bold text-dark-green" style="font-size: 0.85rem;">
                        @role
                    </span>
                    <span class="text-muted" style="font-size: 0.72rem;">Növbətçi Admin</span>
                </div>
            </a>
            <ul class="dropdown-menu dropdown-menu-custom w-100 shadow text-small" aria-labelledby="dropdownUser">
                <li>
                    <a class="dropdown-item dropdown-item-custom" href="/Account/ChangePassword">
                        <i class="bi bi-shield-lock me-2 text-green-primary"></i>Şifrəni Dəyiş
                    </a>
                </li>
                <li><hr class="dropdown-divider my-1" style="border-color: var(--border-color);"></li>
                <li>
                    <div class="sidebar-footer">
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="logout-btn">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>Sistemdən çıxış</span>
                            </button>
                        </form>
                    </div>
                </li>
            </ul>
        </div>
    </div>

    <main class="main-content">
        <header class="top-header d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3">
            <div>
                <h5 class="m-0 fw-bold text-dark-green" style="font-size: 1.05rem;">
                    Xoş gəldiniz, @fullName
                </h5>
                <p class="text-muted m-0 small" style="font-size: 0.78rem;">Uğurlu iş günləri arzulayırıq!</p>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="badge d-flex align-items-center gap-1.5 px-3 py-2 rounded-pill border fw-semibold" style="background-color: #f0fdf4; color: var(--accent-green); border-color: #bbf7d0 !important; font-size: 0.78rem;">
                    <span class="d-inline-block rounded-circle bg-success" style="width: 6px; height: 6px;"></span> Aptek Aktiv
                </span>
                <span class="text-muted fw-bold px-3 py-1.5 rounded-3" id="liveClock" style="font-size: 0.82rem; background-color: #ffffff; border: 1px solid var(--border-color);"></span>
            </div>
        </header>

        <div class="content-body">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function updateClock() {
        const now = new Date();
        const dateString = now.toLocaleDateString('az-AZ', { day: '2-digit', month: '2-digit', year: 'numeric' });
        const timeString = now.toLocaleTimeString('az-AZ', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        document.getElementById('liveClock').innerHTML = `<i class="bi bi-clock me-1 text-muted"></i> ${dateString} &nbsp;|&nbsp; ${timeString}`;
        }
        setInterval(updateClock, 1000);
        updateClock();
    </script>
</body>
</html>