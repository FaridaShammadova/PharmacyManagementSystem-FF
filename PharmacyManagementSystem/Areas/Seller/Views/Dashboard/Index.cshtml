@{
    Layout = "~/Areas/Seller/Views/Shared/_SellerLayout.cshtml";
}

<div class="container-fluid p-0 animate-fade-in">

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm border-start border-4 border-success" style="border-left-color: #16a34a !important;">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-muted text-uppercase fs-7 fw-semibold mb-1">Günlük Satış (Kassa)</h6>
                        <h3 class="fw-bold mb-0 text-dark">142.50 AZN</h3>
                    </div>
                    <div class="bg-success-subtle p-3 rounded-circle" style="background-color: #f0fdf4;">
                        <i class="bi bi-currency-azn fs-3 text-success" style="color: #16a34a !important;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm border-start border-4 border-info" style="border-left-color: #0d6efd !important;">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-muted text-uppercase fs-7 fw-semibold mb-1">Gözləyən Sifarişlər</h6>
                        <h3 class="fw-bold mb-0 text-dark">3 Sifariş</h3>
                    </div>
                    <div class="bg-info-subtle p-3 rounded-circle" style="background-color: #f0f9ff;">
                        <i class="bi bi-cart-check fs-3 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm border-start border-4 border-danger" style="border-left-color: #dc3545 !important;">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-muted text-uppercase fs-7 fw-semibold mb-1">Kritik Stok / Tarixi Bitənlər</h6>
                        <h3 class="fw-bold mb-0 text-danger">5 Məhsul</h3>
                    </div>
                    <div class="bg-danger-subtle p-3 rounded-circle" style="background-color: #fef2f2;">
                        <i class="bi bi-exclamation-octagon fs-3 text-danger"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-dark mb-4">Sürətli Əməliyyatlar</h5>
                    <div class="d-grid gap-3">
                        <a href="/Seller/POS" class="btn p-3 text-start d-flex align-items-center justify-content-between text-white" style="background-color: #0f766e;">
                            <span><i class="bi bi-cpu me-2"></i> Yeni Kassaya Satış</span>
                            <i class="bi bi-arrow-right"></i>
                        </a>
                        <a href="/Seller/Inventory" class="btn p-3 text-start d-flex align-items-center justify-content-between btn-light border">
                            <span><i class="bi bi-plus-circle me-2 text-success"></i> Stoku Artır (Dərman Gəlib)</span>
                            <i class="bi bi-arrow-right text-muted"></i>
                        </a>
                        <a href="/Seller/Order" class="btn p-3 text-start d-flex align-items-center justify-content-between btn-light border">
                            <span><i class="bi bi-receipt me-2 text-primary"></i> Onlayn Sifarişləri Yoxla</span>
                            <i class="bi bi-arrow-right text-muted"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="card-title fw-bold text-dark m-0">Bugünkü Son Satışlar</h5>
                        <span class="badge rounded-pill px-3 py-2 text-dark" style="background-color: #f0fdf4; color: #0f766e !important;">Cəmi: 6 Satış</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light text-secondary fs-7 text-uppercase">
                                <tr>
                                    <th>Çek No</th>
                                    <th>Dərman Adı</th>
                                    <th>Saat</th>
                                    <th>Miqdar</th>
                                    <th>Məbləğ</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-medium text-primary">#CK-9841</td>
                                    <td>Aspirin 100mg (Bayers)</td>
                                    <td class="text-muted">11:20</td>
                                    <td>2 qutu</td>
                                    <td class="fw-semibold">7.40 AZN</td>
                                </tr>
                                <tr>
                                    <td class="fw-medium text-primary">#CK-9840</td>
                                    <td>Nurofen Express 200mg</td>
                                    <td class="text-muted">10:45</td>
                                    <td>1 qutu</td>
                                    <td class="fw-semibold">5.20 AZN</td>
                                </tr>
                                <tr>
                                    <td class="fw-medium text-primary">#CK-9839</td>
                                    <td>Paracetamol 500mg <span class="badge bg-warning text-dark fs-8 ms-1">Reseptli</span></td>
                                    <td class="text-muted">09:15</td>
                                    <td>3 qutu</td>
                                    <td class="fw-semibold">2.10 AZN</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<style>
    .fs-7 {
        font-size: 0.85rem;
    }

    .fs-8 {
        font-size: 0.75rem;
    }

    .animate-fade-in {
        animation: fadeIn 0.4s ease-in-out;
    }
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>