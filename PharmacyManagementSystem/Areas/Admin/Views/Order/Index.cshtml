@model List<OrderViewModel>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Sifarişlər";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="orders-content-wrapper p-4">

    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
        <div>
            <h3 class="fw-bold text-dark-green m-0 tracking-tight" style="color: #1e3a2b; letter-spacing: -0.5px;">Sifarişlərin İdarə Edilməsi</h3>
            <p class="text-muted small m-0 mt-1">Sistemə daxil olan bütün aptek sifarişləri, statuslar və çatdırılma məlumatları</p>
        </div>
    </div>

    <div class="bg-white rounded-4 p-3 mb-4 shadow-sm" style="border: 1px solid #eef2f0;">
        <form method="get" autocomplete="off">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md-4 col-lg-3 position-relative d-flex align-items-center">
                    <i class="bi bi-filter-square position-absolute text-muted" style="left: 14px; z-index: 5;"></i>
                    <select name="status" class="form-select filter-select-custom ps-5">
                        <option value="">Bütün Statuslar</option>
                        @foreach (OrderStatus status in Enum.GetValues(typeof(OrderStatus)))
                        {
                            <option value="@status">
                                @EnumHelper.GetDescription(status)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-3 col-lg-2">
                    <button type="submit" class="btn btn-green-action rounded-3 fw-semibold w-100 py-2">
                        <i class="bi bi-funnel me-1"></i> Filtrlə
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="bg-white rounded-4 shadow-sm overflow-hidden" style="border: 1px solid #eef2f0;">
        <div class="table-responsive">
            <table class="table table-custom align-middle m-0">
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 80px;">Sifariş #</th>
                        <th>İstifadəçi</th>
                        <th>Ümumi Məbləğ</th>
                        <th>Status</th>
                        <th>Çatdırılma Ünvanı</th>
                        <th>Tarix</th>
                        <th class="text-end pe-4" style="width: 140px;">Əməliyyat</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var order in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary" style="font-size: 0.85rem;">#@order.Id</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="user-avatar-subtle">
                                            <i class="bi bi-person text-success"></i>
                                        </div>
                                        <span class="text-dark fw-medium fs-7 text-truncate d-inline-block" style="max-width: 150px;" title="@order.UserId">
                                            @order.UserId
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-bold text-success-price fs-7">
                                        @order.TotalPrice.ToString("0.00") ₼
                                    </span>
                                </td>
                                <td>
                                    @switch (order.Status)
                                    {
                                        case OrderStatus.Pending:
                                            <span class="badge-status status-pending">
                                                <span class="status-dot"></span> Gözləmədə
                                            </span>
                                            break;

                                        case OrderStatus.Preparing:
                                            <span class="badge-status status-confirmed">
                                                <span class="status-dot"></span> Təsdiqləndi
                                            </span>
                                            break;

                                        case OrderStatus.Shipping:
                                            <span class="badge-status status-shipped">
                                                <span class="status-dot"></span> Yoldadır
                                            </span>
                                            break;

                                        case OrderStatus.Delivered:
                                            <span class="badge-status status-delivered">
                                                <span class="status-dot"></span> Çatdırıldı
                                            </span>
                                            break;

                                        case OrderStatus.Cancelled:
                                            <span class="badge-status status-cancelled">
                                                <span class="status-dot"></span> Ləğv Edildi
                                            </span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <span class="text-muted fs-7 d-inline-block text-truncate" style="max-width: 200px;" title="@order.DeliveryAddress">
                                        @order.DeliveryAddress
                                    </span>
                                </td>
                                <td>
                                    <div class="text-dark fs-7 fw-medium">
                                        <i class="bi bi-clock text-muted me-1 small"></i> @order.CreatedAt.ToString("dd.MM.yyyy")
                                    </div>
                                </td>
                                <td class="text-end pe-4">

                                    <div class="d-flex flex-column gap-2 align-items-end">

                                        <a asp-area="Admin"
                                           asp-controller="Order"
                                           asp-action="Details"
                                           asp-route-id="@order.Id"
                                           class="btn btn-action-details rounded-3 fw-semibold shadow-sm">
                                            <i class="bi bi-eye me-1"></i> Ətraflı
                                        </a>

                                        <form asp-action="ChangeStatus"
                                              method="post"
                                              class="w-100">

                                            <input type="hidden"
                                                   name="id"
                                                   value="@order.Id" />
                                        </form>

                                    </div>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-receipt-cutoff display-6 d-block mb-3 text-light-muted"></i>
                                <span class="fw-medium fs-7">Heç bir sifariş tapılmadı.</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .orders-content-wrapper {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .fs-7 {
        font-size: 0.85rem !important;
    }

    .fs-8 {
        font-size: 0.75rem !important;
    }

    .filter-select-custom {
        border-radius: 10px !important;
        border: 1.5px solid #e2e8e5 !important;
        font-size: 0.88rem !important;
        padding-top: 10px !important;
        padding-bottom: 10px !important;
        background-color: #f8faf9 !important;
        color: #334139 !important;
        box-shadow: none !important;
    }

        .filter-select-custom:focus {
            border-color: #4b936c !important;
            background-color: #ffffff !important;
        }

    .btn-green-action {
        background-color: #4b936c;
        color: #ffffff;
        border: none;
        font-size: 0.88rem !important;
        transition: all 0.2s ease;
    }

        .btn-green-action:hover {
            background-color: #3d7a58;
            color: #ffffff;
            transform: translateY(-1px);
        }

    .table-custom {
        background-color: #ffffff;
    }

        .table-custom thead th {
            font-size: 0.78rem;
            font-weight: 700;
            color: #6c7a72;
            padding: 16px 20px;
            background-color: #f8faf9 !important;
            border-bottom: 1px solid #eef2f0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .table-custom tbody tr {
            transition: background-color 0.2s ease;
        }

            .table-custom tbody tr:hover {
                background-color: #fcfdfe;
            }

        .table-custom tbody td {
            padding: 16px 20px;
            border-bottom: 1px solid #f6f9f7;
        }

    .user-avatar-subtle {
        width: 30px;
        height: 30px;
        background-color: #eaf6ed;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.88rem;
    }

    .text-success-price {
        color: #16a34a;
    }

    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

        .badge-status .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }

    .status-pending {
        background-color: #fffbeb;
        color: #d97706;
    }

        .status-pending .status-dot {
            background-color: #d97706;
        }

    .status-confirmed {
        background-color: #eff6ff;
        color: #2563eb;
    }

        .status-confirmed .status-dot {
            background-color: #2563eb;
        }

    .status-shipped {
        background-color: #ecfeff;
        color: #0891b2;
    }

        .status-shipped .status-dot {
            background-color: #0891b2;
        }

    .status-delivered {
        background-color: #f0fdf4;
        color: #16a34a;
    }

        .status-delivered .status-dot {
            background-color: #16a34a;
        }

    .status-cancelled {
        background-color: #fef2f2;
        color: #dc2626;
    }

        .status-cancelled .status-dot {
            background-color: #dc2626;
        }

    .btn-action-details {
        background-color: #ffffff;
        color: #4b936c;
        border: 1.5px solid #daede1;
        font-size: 0.8rem !important;
        padding: 6px 14px;
        transition: all 0.2s ease;
    }

        .btn-action-details:hover {
            background-color: #4b936c;
            color: #ffffff;
            border-color: #4b936c;
            transform: translateY(-1px);
        }

    .text-light-muted {
        color: #ccd6d1;
    }
</style>