@model OrderViewModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Sifariş Məlumatları";
}

<div class="order-details-wrapper p-4">

    <div class="mb-4">
        <a href="/Admin/Order" class="back-link-custom">
            <i class="bi bi-arrow-left-short fs-5"></i> Sifariş siyahısına qayıt
        </a>
        <h3 class="fw-bold mt-2 m-0 tracking-tight" style="color: #1e3a2b; letter-spacing: -0.5px;">Sifariş #@Model.Id Məlumatları</h3>
        <p class="text-muted small m-0 mt-1">Sifarişin cari statusunu dəyişdirə və satışı edilən preparatların siyahısını incələyə bilərsiniz.</p>
    </div>

    <div class="row g-4">

        <div class="col-12 col-lg-7">
            <div class="bg-white rounded-4 shadow-sm h-100" style="border: 1px solid #eef2f0;">
                <div class="p-4 border-bottom d-flex align-items-center gap-2" style="background-color: #f8faf9; border-top-left-radius: 16px; border-top-right-radius: 16px;">
                    <i class="bi bi-info-circle text-success fs-5"></i>
                    <h5 class="fw-bold text-dark-green m-0 fs-6">Sifariş İnformasiyası</h5>
                </div>

                <div class="p-4">
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex justify-content-between align-items-center pb-2 border-bottom border-light-subtle">
                            <span class="text-muted fs-7 fw-medium">Ümumi Məbləğ:</span>
                            <span class="fw-bold text-success fs-6">@Model.TotalPrice.ToString("0.00") ₼</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pb-2 border-bottom border-light-subtle">
                            <span class="text-muted fs-7 fw-medium">Cari Status:</span>
                            @switch (Model.Status)
                            {
                                case OrderStatus.Pending:
                                    <span class="badge-status status-pending"><span class="status-dot"></span> Gözləmədə</span>
                                    break;
                                case OrderStatus.Preparing:
                                    <span class="badge-status status-confirmed"><span class="status-dot"></span> Təsdiqləndi</span>
                                    break;
                                case OrderStatus.Shipping:
                                    <span class="badge-status status-shipped"><span class="status-dot"></span> Yoldadır</span>
                                    break;
                                case OrderStatus.Delivered:
                                    <span class="badge-status status-delivered"><span class="status-dot"></span> Çatdırıldı</span>
                                    break;
                                case OrderStatus.Cancelled:
                                    <span class="badge-status status-cancelled"><span class="status-dot"></span> Ləğv Edildi</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary-subtle text-secondary rounded-pill px-2.5 py-1 fs-8">@Model.Status</span>
                                    break;
                            }
                        </div>

                        <div class="pb-2 border-bottom border-light-subtle">
                            <span class="text-muted fs-7 d-block mb-1 fw-medium">Çatdırılma Ünvanı:</span>
                            <span class="text-dark fw-bold fs-7">@Model.DeliveryAddress</span>
                        </div>

                        <div>
                            <span class="text-muted fs-7 d-block mb-1 fw-medium">Sifariş Qeydləri:</span>
                            <div class="p-3 bg-light rounded-3 text-secondary fs-7" style="background-color: #f8faf9 !important; min-height: 60px;">
                                @(string.IsNullOrEmpty(Model.Notes) ? "Qeyd daxil edilməyib." : Model.Notes)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-5">
            <div class="bg-white rounded-4 shadow-sm h-100" style="border: 1px solid #eef2f0;">
                <div class="p-4 border-bottom d-flex align-items-center gap-2" style="background-color: #f8faf9; border-top-left-radius: 16px; border-top-right-radius: 16px;">
                    <i class="bi bi-arrow-left-right text-success fs-5"></i>
                    <h5 class="fw-bold text-dark-green m-0 fs-6">Statusun Yenilənməsi</h5>
                </div>

                <div class="p-4">
                    <form asp-area="Admin"
                          asp-controller="Order"
                          asp-action="ChangeStatus"
                          method="post"
                          autocomplete="off">

                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="mb-4">
                            <label class="form-label-custom mb-2">Yeni Status Təyin Et</label>
                            <div class="position-relative d-flex align-items-center">
                                <i class="bi bi-gear position-absolute text-muted" style="left: 14px; z-index: 5;"></i>
                                <select name="status" class="form-select select-custom ps-5">
                                    @foreach (OrderStatus status in Enum.GetValues(typeof(OrderStatus)))
                                    {
                                        <option value="@status" selected="@(status == Model.Status)">
                                            @status
                                        </option>
                                    }
                                </select>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-green-action rounded-3 fw-semibold w-100 py-2-5 shadow-sm">
                            <i class="bi bi-check2-circle me-1"></i> Statusu Yenilə
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>

    <div class="bg-white rounded-4 shadow-sm overflow-hidden mt-4" style="border: 1px solid #eef2f0;">
        <div class="p-4 border-bottom d-flex align-items-center gap-2" style="background-color: #f8faf9;">
            <i class="bi bi-capsule text-success fs-5"></i>
            <h5 class="fw-bold text-dark-green m-0 fs-6">Sifariş Paketindəki Preparatlar</h5>
        </div>

        <div class="table-responsive">
            <table class="table table-custom align-middle m-0">
                <thead>
                    <tr>
                        <th class="ps-4">Dərman Adı</th>
                        <th style="width: 150px;">Say (Miqdar)</th>
                        <th style="width: 180px;">Vahid Qiymət</th>
                        <th class="text-end pe-4" style="width: 180px;">Cəmi Məbləğ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="medicine-icon-wrapper"><i class="bi bi-capsule-contained text-success"></i></div>
                                    <span class="fw-bold text-dark fs-7">@item.MedicineName</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border px-3 py-1.5 rounded-pill fw-medium fs-8">
                                    @item.Quantity ədəd
                                </span>
                            </td>
                            <td class="text-secondary fs-7 fw-medium">@item.Price.ToString("0.00") ₼</td>
                            <td class="text-end pe-4 fw-bold text-success-price fs-7">
                                @((item.Price * item.Quantity).ToString("0.00")) ₼
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .order-details-wrapper {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .text-dark-green {
        color: #1e3a2b;
    }

    .fs-7 {
        font-size: 0.85rem !important;
    }

    .fs-8 {
        font-size: 0.75rem !important;
    }

    .py-2-5 {
        padding-top: 11px !important;
        padding-bottom: 11px !important;
    }

    .back-link-custom {
        text-decoration: none;
        color: #707e76;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: color 0.2s ease;
        font-weight: 500;
    }

        .back-link-custom:hover {
            color: #4b936c !important;
        }

    .form-label-custom {
        font-size: 0.85rem;
        font-weight: 600;
        color: #434d47;
        display: block;
    }

    .select-custom {
        border-radius: 10px !important;
        border: 1.5px solid #e2e8e5 !important;
        font-size: 0.9rem !important;
        padding-top: 11px !important;
        padding-bottom: 11px !important;
        background-color: #f8faf9 !important;
        color: #2d3732 !important;
        box-shadow: none !important;
        outline: none !important;
        transition: all 0.2s ease;
    }

        .select-custom:focus {
            border-color: #4b936c !important;
            background-color: #ffffff !important;
            box-shadow: 0 0 0 4px rgba(75, 147, 108, 0.1) !important;
        }

    .btn-green-action {
        background-color: #4b936c;
        color: #ffffff;
        border: none;
        font-size: 0.88rem !important;
        transition: all 0.2s ease;
    }

        .btn-green-action:hover {
            background-color: #3d7a58;
            color: #ffffff;
            transform: translateY(-1px);
        }

    .table-custom thead th {
        font-size: 0.78rem;
        font-weight: 700;
        color: #6c7a72;
        padding: 16px 20px;
        background-color: #f8faf9 !important;
        border-bottom: 1px solid #eef2f0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .table-custom tbody tr:hover {
        background-color: #fcfdfe;
    }

    .table-custom tbody td {
        padding: 14px 20px;
        border-bottom: 1px solid #f6f9f7;
    }

    .medicine-icon-wrapper {
        width: 28px;
        height: 28px;
        background-color: #eaf6ed;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
    }

    .text-success-price {
        color: #16a34a;
    }

    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

        .badge-status .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }

    .status-pending {
        background-color: #fffbeb;
        color: #d97706;
    }

        .status-pending .status-dot {
            background-color: #d97706;
        }

    .status-confirmed {
        background-color: #eff6ff;
        color: #2563eb;
    }

        .status-confirmed .status-dot {
            background-color: #2563eb;
        }

    .status-shipped {
        background-color: #ecfeff;
        color: #0891b2;
    }

        .status-shipped .status-dot {
            background-color: #0891b2;
        }

    .status-delivered {
        background-color: #f0fdf4;
        color: #16a34a;
    }

        .status-delivered .status-dot {
            background-color: #16a34a;
        }

    .status-cancelled {
        background-color: #fef2f2;
        color: #dc2626;
    }

        .status-cancelled .status-dot {
            background-color: #dc2626;
        }
</style>