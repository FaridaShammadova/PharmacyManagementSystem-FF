@model IEnumerable<MedicineViewModel>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dərmanlar";
}

<div class="medicine-page-wrapper">

    <div class="med-header-flex">
        <div>
            <h3 class="med-main-title">Dərman Anbarı</h3>
            <p class="med-subtitle">Mövcud dərmanların siyahısı, qiymətləri, resept tələbi və ətraflı stok vəziyyəti</p>
        </div>

        <a href="/Admin/Medicine/Create" class="create-med-btn">
            <i class="bi bi-plus-circle-fill"></i> Yeni Dərman Əlavə Et
        </a>
    </div>

    <div class="med-card-table">
        <div class="custom-table-responsive">
            <table class="custom-premium-table">
                <thead>
                    <tr>
                        <th style="width: 80px; text-align: center;">Şəkil</th>
                        <th>Dərman Adı</th>
                        <th>Barkod</th>
                        <th>Qiymət / Endirim</th>
                        <th>Resept</th>
                        <th>Son İstifadə T.</th>
                        <th>Stok Miqdarı</th>
                        <th style="text-align: right;">Əməliyyatlar</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="no-data-text">
                                <i class="bi bi-capsule-thumbnail text-muted d-block mb-2" style="font-size: 2.2rem;"></i>
                                Anbarda heç bir dərman tapılmadı
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="text-align: center;">
                                <div class="med-icon-box mx-auto">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-capsule text-success-custom"></i>
                                    }
                                </div>
                            </td>

                            <td>
                                <div class="med-name-text">@item.Name</div>
                                <div class="med-sub-details">
                                    <span class="badge-manufacturer" title="İstehsalçı">
                                        <i class="bi bi-building"></i> @item.Manufacturer
                                    </span>
                                    <span class="badge-category" title="Kateqoriya">
                                        <i class="bi bi-tag"></i> @(item.CategoryName ?? "Kateqoriyasız")
                                    </span>
                                </div>
                            </td>

                            <td>
                                <span class="barcode-text"><i class="bi bi-barcode me-1"></i> @item.Barcode</span>
                            </td>

                            <td>
                                <div class="d-flex flex-column">
                                    @if (item.DiscountPrice.HasValue && item.DiscountPrice.Value < item.Price)
                                    {
                                        <span class="text-decoration-line-through text-muted small">@item.Price.ToString("0.00") ₼</span>
                                        <span class="fw-bold text-danger">@item.DiscountPrice.Value.ToString("0.00") ₼</span>
                                    }
                                    else
                                    {
                                        <span class="fw-bold text-dark">@item.Price.ToString("0.00") ₼</span>
                                    }
                                </div>
                            </td>

                            <td>
                                @if (item.RequiresPrescription)
                                {
                                    <span class="badge-prescription prescription-required">
                                        <i class="bi bi-file-earmark-medical-fill"></i> Reseptli
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-prescription prescription-free">
                                        <i class="bi bi-check-lg"></i> Sərbəst
                                    </span>
                                }
                            </td>

                            <td>
                                @{
                                    var isExpired = item.ExpireDate <= DateTime.Now;
                                    var isNearExpired = !isExpired && item.ExpireDate <= DateTime.Now.AddMonths(3);
                                }
                                <span class="date-text @(isExpired ? "text-danger fw-bold" : isNearExpired ? "text-warning fw-bold" : "")">
                                    <i class="bi bi-calendar-event me-1"></i> @item.ExpireDate.ToString("dd.MM.yyyy")
                                    @if (isExpired)
                                    {
                                        <small class="d-block text-danger">(Bitib!)</small>
                                    }
                                    else if (isNearExpired)
                                    {

                                        <small class="d-block text-warning">(Az qalıb)</small>
                                    }
                                </span>
                            </td>

                            <td>
                                @if (item.StockQuantity <= 10)
                                {
                                    <span class="stock-badge stock-critical">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i> @item.StockQuantity ədəd
                                    </span>
                                }
                                else if (item.StockQuantity <= 30)
                                {
                                    <span class="stock-badge stock-warning">
                                        <i class="bi bi-clock-history me-1"></i> @item.StockQuantity ədəd
                                    </span>
                                }
                                else
                                {
                                    <span class="stock-badge stock-normal">
                                        <i class="bi bi-check-circle-fill me-1"></i> @item.StockQuantity ədəd
                                    </span>
                                }
                            </td>

                            <td style="text-align: right;">
                                <div class="d-flex justify-content-end gap-2">
                                    <form asp-action="Edit"
                                          asp-route-id="@item.Id"
                                          method="get"
                                          style="display:inline;">

                                        <button type="submit"
                                                class="table-action-btn btn-edit-style border-0"
                                                title="Düzəliş et">

                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                    </form>

                                    <form asp-action="Delete"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          style="display:inline;">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="table-action-btn btn-delete-style border-0"
                                                title="Sil"
                                                onclick="return confirm('Bu dərmanı silmək istədiyinizə əminsiniz?')">

                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .medicine-page-wrapper {
        padding: 30px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #fafcfb;
    }

    .med-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 25px;
    }

    .med-main-title {
        font-weight: 700;
        color: #1e3a2b;
        margin: 0;
        font-size: 1.55rem;
        letter-spacing: -0.5px;
    }

    .med-subtitle {
        color: #6e7c73;
        font-size: 0.88rem;
        margin: 5px 0 0 0;
    }

    .create-med-btn {
        background-color: #4b936c;
        color: #ffffff !important;
        text-decoration: none !important;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 0.88rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(75, 147, 108, 0.15);
        transition: all 0.2s ease;
    }

        .create-med-btn:hover {
            background-color: #397353;
            transform: translateY(-1px);
            box-shadow: 0 6px 15px rgba(75, 147, 108, 0.25);
        }

    .med-card-table {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #eef2f0;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
        overflow: hidden;
    }

    .custom-table-responsive {
        width: 100%;
        overflow-x: auto;
    }

    .custom-premium-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .custom-premium-table th {
            background-color: #f4f7f5;
            color: #434d47;
            font-weight: 600;
            font-size: 0.82rem;
            padding: 16px 20px;
            border-bottom: 1.5px solid #e2e8e5;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .custom-premium-table td {
            padding: 14px 20px;
            border-bottom: 1px solid #edf1ef;
            color: #2d3732;
            font-size: 0.9rem;
            vertical-align: middle;
        }

        .custom-premium-table tbody tr:hover {
            background-color: #f9fbf9;
        }

    .no-data-text {
        text-align: center !important;
        padding: 60px 0 !important;
        color: #8fa096 !important;
        font-size: 0.95rem;
    }

    .med-icon-box {
        width: 44px;
        height: 44px;
        background-color: #e6f7ed;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        overflow: hidden;
        border: 1px solid #daede1;
    }

        .med-icon-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .text-success-custom {
        color: #4b936c;
        font-size: 1.3rem;
    }

    .med-name-text {
        font-weight: 700;
        color: #1a241e;
        font-size: 0.98rem;
    }

    .med-sub-details {
        display: flex;
        gap: 6px;
        margin-top: 4px;
    }

    .badge-manufacturer, .badge-category {
        font-size: 0.72rem;
        font-weight: 500;
        padding: 2px 6px;
        border-radius: 4px;
        background-color: #f0f3f1;
        color: #55635a;
    }

    .barcode-text, .date-text {
        font-size: 0.85rem;
        color: #4b5750;
        white-space: nowrap;
    }

    .badge-prescription {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 0.78rem;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 6px;
        white-space: nowrap;
    }

    .prescription-required {
        background-color: #fff1f2;
        color: #e11d48;
    }

    .prescription-free {
        background-color: #f0fdf4;
        color: #16a34a;
    }

    .stock-badge {
        display: inline-flex;
        align-items: center;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .stock-normal {
        background-color: #e6f7ed;
        color: #247a46;
    }

    .stock-warning {
        background-color: #fffbeb;
        color: #b45309;
    }

    .stock-critical {
        background-color: #fdeeee;
        color: #b32b2b;
    }

    .table-action-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1.5px solid transparent;
        font-size: 1rem;
    }

    .btn-edit-style {
        color: #2563eb;
        border-color: #e0f2fe;
        background-color: #f0f9ff;
    }

        .btn-edit-style:hover {
            background-color: #2563eb;
            color: #ffffff !important;
        }

    .btn-delete-style {
        color: #b32b2b;
        border-color: #fcdede;
        background-color: #fdf4f4;
    }

        .btn-delete-style:hover {
            background-color: #b32b2b;
            color: #ffffff !important;
        }
</style>
