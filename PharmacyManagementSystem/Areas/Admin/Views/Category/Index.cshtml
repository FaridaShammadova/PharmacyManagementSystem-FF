@model IEnumerable<CategoryViewModel>

@{
    ViewData["Title"] = "Kateqoriyalar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="category-content-wrapper p-4">

    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
        <div>
            <h3 class="fw-bold text-dark-green m-0 tracking-tight" style="color: #1e3a2b; letter-spacing: -0.5px;">Sistem Kateqoriyaları</h3>
            <p class="text-muted small m-0 mt-1">Dərman preparatlarının qruplaşdırılması və filtrasiyası üçün əsas bölmələr</p>
        </div>
        <div>
            <a href="/Admin/Category/Create" class="btn btn-green-action rounded-3 fw-semibold px-4 py-2-5 shadow-sm">
                <i class="bi bi-plus-lg me-2"></i> Yeni Kateqoriya Əlavə Et
            </a>
        </div>
    </div>

    <div class="bg-white rounded-4 shadow-sm overflow-hidden" style="border: 1px solid #eef2f0;">
        <div class="table-responsive">
            <table class="table table-custom align-middle m-0">
                <thead>
                    <tr>
                        <th style="width: 80px;" class="ps-4">#</th>
                        <th>Kateqoriya Adı</th>
                        <th style="width: 200px;" class="text-end pe-4">Əməliyyatlar</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int counter = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-semibold" style="font-size: 0.85rem;">#@counter</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="category-icon-dot"></div>
                                        <span class="fw-bold text-dark" style="font-size: 0.9rem;">@item.Name</span>
                                    </div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/Admin/Category/Edit/@item.Id" class="btn btn-action-edit rounded-3" title="Düzəliş et">
                                            <i class="bi bi-pencil-square text-primary"></i>
                                        </a>
                                        <a href="/Admin/Category/Delete/@item.Id" class="btn btn-action-delete rounded-3" title="Sil">
                                            <i class="bi bi-trash3 text-danger"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            counter++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <i class="bi bi-folder-x display-6 d-block mb-3 text-light-muted"></i>
                                <span class="fw-medium fs-7">Sistemdə hələ ki heç bir kateqoriya tapılmadı.</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .category-content-wrapper {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .btn-green-action {
        background-color: #4b936c;
        color: #ffffff;
        border: none;
        font-size: 0.88rem !important;
        transition: all 0.2s ease;
    }

        .btn-green-action:hover {
            background-color: #3d7a58;
            color: #ffffff;
            transform: translateY(-1px);
        }

    .py-2-5 {
        padding-top: 11px !important;
        padding-bottom: 11px !important;
    }

    .table-custom thead th {
        font-size: 0.78rem;
        font-weight: 700;
        color: #6c7a72;
        padding: 16px 20px;
        background-color: #f8faf9 !important;
        border-bottom: 1px solid #eef2f0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .table-custom tbody tr {
        transition: background-color 0.2s ease;
    }

        .table-custom tbody tr:hover {
            background-color: #fcfdfe;
        }

    .table-custom tbody td {
        padding: 16px 20px;
        border-bottom: 1px solid #f6f9f7;
    }

    .category-icon-dot {
        width: 8px;
        height: 8px;
        background-color: #4b936c;
        border-radius: 50%;
        opacity: 0.7;
    }

    .btn-action-edit, .btn-action-delete {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #eef2f0;
        background-color: #ffffff;
        font-size: 0.95rem;
        transition: all 0.2s ease;
        padding: 0;
    }

        .btn-action-edit:hover {
            background-color: #eff6ff;
            border-color: #bfdbfe;
            transform: translateY(-1px);
        }

        .btn-action-delete:hover {
            background-color: #fef2f2;
            border-color: #fecaca;
            transform: translateY(-1px);
        }

    .text-light-muted {
        color: #ccd6d1;
    }

    .fs-7 {
        font-size: 0.85rem !important;
    }
</style>