@model CategoryCreateViewModel
@{
    ViewData["Title"] = "Yeni Kateqoriya";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}


<div class="category-create-wrapper p-4">
    <div class="form-container-custom mx-auto" style="max-width: 600px; width: 100%;">

        <div class="mb-4">
            <a href="/Admin/Category" class="back-link-custom">
                <i class="bi bi-arrow-left-short fs-5"></i> Kateqoriyalara qayıt
            </a>
            <h3 class="fw-bold mt-2 m-0 tracking-tight" style="color: #1e3a2b; letter-spacing: -0.5px;">Yeni Kateqoriya Əlavə Et</h3>
            <p class="text-muted small m-0 mt-1">Dərman preparatlarını sistemdə qruplaşdırmaq üçün yeni bir kateqoriya adı daxil edin.</p>
        </div>

        <div class="bg-white rounded-4 p-4 p-md-5 shadow-sm" style="border: 1px solid #eef2f0;">
            <form method="post" autocomplete="off">

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-4 p-3 rounded-3" style="border: none; background-color: #fdf2f2; color: #de3a3a;"></div>

                <div class="form-group-custom mb-4">
                    <label asp-for="Name" class="form-label-custom">Kateqoriya Adı</label>
                    <div class="position-relative d-flex align-items-center">
                        <i class="bi bi-tags position-absolute text-muted" style="left: 16px; font-size: 1.05rem; pointer-events: none;"></i>
                        <input asp-for="Name" class="form-control input-custom" placeholder="Məs: Antibiotiklər, Ağrıkəsicilər, Vitaminlər" />
                    </div>
                    <span asp-validation-for="Name" class="text-danger mt-1 d-block fw-medium" style="font-size: 0.78rem;"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 pt-3 border-top border-light-subtle">
                    <a href="/Admin/Category" class="btn rounded-3 fw-semibold px-4 py-2-5 cancel-btn">Ləğv et</a>
                    <button type="submit" class="btn rounded-3 fw-semibold px-4 py-2-5 shadow-sm action-btn">
                        <i class="bi bi-check2-circle me-1"></i> Kateqoriyanı Yadda Saxla
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .category-create-wrapper {
        padding: 40px 20px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .back-link-custom {
        text-decoration: none;
        color: #707e76;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: color 0.2s ease;
        font-weight: 500;
    }

        .back-link-custom:hover {
            color: #4b936c !important;
        }

    .form-label-custom {
        font-size: 0.85rem;
        font-weight: 600;
        color: #434d47;
        margin-bottom: 8px;
        display: block;
    }

    .input-custom {
        padding: 12px 16px 12px 46px !important;
        border-radius: 10px !important;
        border: 1.5px solid #e2e8e5 !important;
        font-size: 0.9rem !important;
        outline: none !important;
        box-shadow: none !important;
        transition: all 0.2s ease;
        color: #2d3732;
        background-color: #f8faf9;
    }

        .input-custom:focus {
            border-color: #4b936c !important;
            background-color: #ffffff !important;
            box-shadow: 0 0 0 4px rgba(75, 147, 108, 0.1) !important;
        }

    .py-2-5 {
        padding-top: 11px !important;
        padding-bottom: 11px !important;
    }

    .action-btn {
        background-color: #4b936c;
        color: #ffffff;
        border: none;
        font-size: 0.88rem !important;
        transition: all 0.2s ease;
    }

        .action-btn:hover {
            background-color: #3d7a58;
            color: #ffffff;
            transform: translateY(-1px);
        }

    .cancel-btn {
        background-color: #f1f4f2;
        color: #55635a;
        border: none;
        font-size: 0.88rem !important;
        transition: all 0.2s ease;
    }

        .cancel-btn:hover {
            background-color: #e2e7e4;
            color: #2d3732;
        }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}