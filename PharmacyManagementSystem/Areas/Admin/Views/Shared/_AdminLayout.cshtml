@inject AppDbContext _context

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pharmacy Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            :root {
                --sidebar-width: 260px;
                --primary-green: #4b936c;
                --dark-green: #14281d;
                --sidebar-hover: rgba(255, 255, 255, 0.05);
                --light-bg: #fafcfb;
            }

            body {
                font-family: 'Plus Jakarta Sans', sans-serif !important;
                background-color: var(--light-bg) !important;
                margin: 0;
                padding: 0;
                overflow-x: hidden;
            }

            .admin-container {
                display: flex;
                width: 100vw;
                height: 100vh;
            }

            .admin-sidebar {
                width: var(--sidebar-width);
                background-color: var(--dark-green);
                color: #fff;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                height: 100vh;
                position: fixed;
                left: 0;
                top: 0;
            }

            .sidebar-brand {
                padding: 24px;
                font-weight: 700;
                border-bottom: 1px solid rgba(255,255,255,0.05);
                display: flex;
                gap: 12px;
            }

            .sidebar-menu-wrapper {
                list-style: none;
                padding: 20px 12px;
                margin: 0;
            }

            .sidebar-item a {
                display: flex;
                gap: 12px;
                padding: 12px 16px;
                color: rgba(255,255,255,0.6);
                text-decoration: none;
                border-radius: 10px;
            }

                .sidebar-item a:hover {
                    background: var(--sidebar-hover);
                    color: #fff;
                }

            .admin-main {
                margin-left: var(--sidebar-width);
                width: calc(100vw - var(--sidebar-width));
                display: flex;
                flex-direction: column;
                height: 100vh;
            }

            .admin-topbar {
                height: 70px;
                background: #fff;
                border-bottom: 1px solid #eef2f0;
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0 30px;
            }

            .admin-content {
                flex-grow: 1;
                overflow-y: auto;
                background: #fafcfb;
            }

            .user-avatar {
                width: 36px;
                height: 36px;
                background: #eaf6ed;
                color: var(--primary-green);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
            }

            .sidebar-footer {
                margin-top: auto;
                padding: 16px 12px;
                border-top: 1px solid rgba(255,255,255,0.05);
            }

            .logout-btn {
                width: 100%;
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 16px;
                border: none;
                background: transparent;
                color: #fca5a5;
                font-size: 0.88rem;
                font-weight: 600;
                border-radius: 10px;
                transition: 0.2s;
                cursor: pointer;
            }

                .logout-btn:hover {
                    background: rgba(239, 68, 68, 0.1);
                    color: #ef4444;
                    padding-left: 20px;
                }
    </style>
</head>

@RenderSection("Scripts", required: false)

<body>

    @{
        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);

        var notifications = new List<Notification>();
        var unreadCount = 0;

        if (!string.IsNullOrEmpty(userId))
        {
            notifications = _context.Notifications
                .Where(x => x.UserId == userId)
                .OrderByDescending(x => x.CreatedAt)
                .Take(8)
                .ToList();

            unreadCount = notifications.Count(x => !x.IsRead);
        }
    }

    <div class="admin-container">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <div>
                <div class="sidebar-brand">
                    <i class="bi bi-capsule text-success fs-5"></i>
                    Pharmacy Admin
                </div>

                <ul class="sidebar-menu-wrapper" id="adminNavbarMenu">
                    <li class="sidebar-item">
                        <a href="/Admin/Dashboard"><i class="bi bi-grid-1x2-fill"></i> İdarəetmə paneli</a>
                    </li>
                    <li class="sidebar-item">
                        <a href="/Admin/Seller"><i class="bi bi-people-fill"></i></i> Satıcılar</a>
                    </li>
                    <li class="sidebar-item">
                        <a href="/Admin/Category"><i class="bi bi-tags-fill"></i> Kateqoriyalar</a>
                    </li>
                    <li class="sidebar-item">
                        <a href="/Admin/Medicine"><i class="bi bi-capsule-pill"></i> Dərmanlar</a>
                    </li>
                    <li class="sidebar-item">
                        <a href="/Admin/Order"><i class="bi bi-receipt-cutoff"></i> Sifarişlər</a>
                    </li>
                </ul>
            </div>

            <div class="sidebar-footer">
                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="logout-btn">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Sistemdən çıxış</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- MAIN -->
        <div class="admin-main">

            <!-- TOPBAR -->
            <header class="admin-topbar">

                <button class="btn d-lg-none">
                    <i class="bi bi-list fs-3"></i>
                </button>

                <!-- NOTIFICATION -->
                <div class="dropdown">

                    <button class="btn position-relative border-0 shadow-sm"
                            data-bs-toggle="dropdown"
                            style="width:42px;height:42px;border-radius:12px;background:#fff;">

                        <i class="bi bi-bell-fill fs-5"></i>

                        @if (unreadCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge bg-danger">
                                @unreadCount
                            </span>
                        }
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end shadow p-2" style="width:360px">

                        <li class="px-3 py-2 border-bottom">
                            <b>Bildirişlər</b>
                        </li>

                        @if (!notifications.Any())
                        {
                            <li class="p-3 text-muted text-center">Bildiriş yoxdur</li>
                        }
                        else
                        {
                            @foreach (var n in notifications)
                            {
                                <li>
                                    <div class="dropdown-item py-2">

                                        <b>@n.Title</b><br />
                                        <small>@n.Message</small><br />
                                        <small class="text-muted">@n.CreatedAt</small>

                                        @if (!n.IsRead)
                                        {
                                            <span class="badge bg-success">Yeni</span>
                                        }

                                    </div>
                                </li>
                            }
                        }

                    </ul>
                </div>

                <!-- USER -->
                <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar">A</div>
                </div>

            </header>

            <main class="admin-content">
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
