@model LoginViewModel

@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Giriş";
}



<div class="fixed-register-screen">
    <div class="clean-center-box">
        <div class="pharmacy-clean-card">

            <div class="pcc-header">
                <div class="pcc-logo">
                    <i class="bi bi-capsule"></i>
                </div>
                <div class="pcc-subtitle">Pharmacy Management System</div>
                <div class="pcc-title">Daxil ol</div>
            </div>

            <div class="pcc-body">
                <form asp-action="Login" method="post" autocomplete="off">

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="pcc-alert">
                            Məlumatlar düzgün deyil və ya belə bir istifadəçi tapılmadı.
                        </div>
                    }

                    <div class="pcc-group">
                        <label asp-for="Email" class="pcc-label">Email</label>
                        <div class="pcc-input-wrapper">
                            <i class="bi bi-envelope pcc-icon"></i>
                            <input asp-for="Email" type="email" class="pcc-input" placeholder="ornek@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="pcc-error"></span>
                    </div>

                    <div class="pcc-group">
                        <label asp-for="Password" class="pcc-label">Şifrə</label>
                        <div class="pcc-input-wrapper">
                            <i class="bi bi-lock pcc-icon"></i>
                            <input asp-for="Password" type="password" id="loginPasswordInput" class="pcc-input" placeholder="••••••••" />
                            <button type="button" class="pcc-toggle" onclick="togglePassword('loginPasswordInput', 'loginPassIcon')">
                                <i id="loginPassIcon" class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="pcc-error"></span>
                    </div>

                    <button type="submit" class="pcc-btn">
                        DAXİL OLUN <i class="bi bi-box-arrow-in-right ms-1"></i>
                    </button>

                    <div class="pcc-footer">
                        <a href="#" class="pcc-link-muted">Şifrənizi unutmusunuz?</a>
                        <div class="pcc-text-muted">Hesabınız yoxdur? <a asp-action="Register" class="pcc-link-green"> Qeydiyyatdan keçin.</a></div>
                    </div>

                </form>
            </div>

        </div
    </div>
</div>

<style>
    html, body {
        margin: 0 !important;
        padding: 0 !important;
        height: 100vh !important;
        width: 100vw !important;
        overflow: hidden !important;
        font-family: 'Plus Jakarta Sans', sans-serif !important;
    }

    .fixed-register-screen {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        background: linear-gradient(180deg, #e2efe7 0%, #f4f7f5 100%) !important;
        z-index: 99999 !important;
        display: block !important;
    }

    .clean-center-box {
        position: absolute !important;
        top: 50% !important;
        left: 50% !important;
        transform: translate(-50%, -50%) !important;
        width: 100% !important;
        max-width: 400px !important;
        padding: 0 15px !important;
        box-sizing: border-box !important;
    }

    .pharmacy-clean-card {
        background: #ffffff !important;
        border-radius: 20px !important;
        box-shadow: 0 15px 35px rgba(80, 100, 90, 0.08) !important;
        overflow: hidden !important;
        border: none !important;
    }

    .pcc-header {
        background: linear-gradient(180deg, #aed9be 0%, #ffffff 100%) !important;
        text-align: center !important;
        padding: 35px 20px 20px 20px !important;
    }

    .pcc-logo {
        width: 42px;
        height: 42px;
        background: #ffffff !important;
        color: #4b936c !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        border-radius: 50% !important;
        font-size: 1.2rem !important;
        box-shadow: 0 3px 10px rgba(0,0,0,0.02) !important;
        margin-bottom: 8px !important;
    }

    .pcc-subtitle {
        font-size: 0.65rem !important;
        font-weight: 700 !important;
        color: #5c846e !important;
        letter-spacing: 1px !important;
        text-transform: uppercase !important;
    }

    .pcc-title {
        font-weight: 700 !important;
        color: #1e3a2b !important;
        font-size: 1.45rem !important;
        margin-top: 4px !important;
    }

    .pcc-body {
        padding: 10px 30px 35px 30px !important;
    }

    .pcc-group {
        margin-bottom: 15px !important;
        text-align: left !important;
    }

    .pcc-label {
        font-size: 0.78rem !important;
        font-weight: 600 !important;
        color: #344a3e !important;
        margin-bottom: 5px !important;
        display: block !important;
    }

    .pcc-input-wrapper {
        position: relative !important;
        display: flex !important;
        align-items: center !important;
    }

    .pcc-icon {
        position: absolute !important;
        left: 14px !important;
        color: #7fa890 !important;
        font-size: 1rem !important;
    }

    .pcc-input {
        width: 100% !important;
        padding: 11px 15px 11px 38px !important;
        font-size: 0.88rem !important;
        color: #2c3e35 !important;
        background-color: #ffffff !important;
        border: 1.5px solid #d2ded6 !important;
        border-radius: 10px !important;
        box-sizing: border-box !important;
        transition: all 0.2s ease !important;
        outline: none !important;
    }

        .pcc-input:focus {
            border-color: #4b936c !important;
            box-shadow: 0 0 0 3px rgba(75, 147, 108, 0.1) !important;
        }

    .pcc-toggle {
        position: absolute !important;
        right: 14px !important;
        background: none !important;
        border: none !important;
        color: #618671 !important;
        font-size: 0.72rem !important;
        cursor: pointer !important;
        display: flex !important;
        align-items: center !important;
        gap: 4px !important;
        padding: 0 !important;
    }

    .pcc-btn {
        width: 100% !important;
        background-color: #4b936c !important;
        color: #ffffff !important;
        border: none !important;
        padding: 12px 20px !important;
        font-size: 0.88rem !important;
        font-weight: 600 !important;
        border-radius: 10px !important;
        cursor: pointer !important;
        margin-top: 10px !important;
        box-shadow: 0 5px 15px rgba(75, 147, 108, 0.2) !important;
        transition: background 0.2s !important;
    }

        .pcc-btn:hover {
            background-color: #3d7a58 !important;
        }

    .pcc-footer {
        text-align: center !important;
        margin-top: 20px !important;
        padding-top: 15px !important;
        border-top: 1px solid #f0f4f1 !important;
    }

    .pcc-link-muted {
        color: #7fa890 !important;
        text-decoration: none !important;
        font-size: 0.75rem !important;
        display: block !important;
        margin-bottom: 6px !important;
    }

    .pcc-text-muted {
        color: #6c757d !important;
        font-size: 0.75rem !important;
    }

    .pcc-link-green {
        color: #4b936c !important;
        text-decoration: none !important;
        font-weight: 600 !important;
    }

        .pcc-link-green:hover {
            text-decoration: underline !important;
        }

    .pcc-error {
        color: #dc3545 !important;
        font-size: 0.72rem !important;
        display: block !important;
        margin-top: 2px !important;
        min-height: 14px !important;
    }

    .pcc-alert {
        background-color: #fdf2f2 !important;
        border: 1px solid #fde2e2 !important;
        color: #de3535 !important;
        padding: 10px !important;
        border-radius: 8px !important;
        font-size: 0.78rem !important;
        text-align: center !important;
        margin-bottom: 15px !important;
    }
</style>

<script>
    function togglePassword(inputId, iconId) {
        var x = document.getElementById(inputId);
        var icon = document.getElementById(iconId);
        if (x.type === "password") {
            x.type = "text";
            icon.classList.replace("bi-eye", "bi-eye-slash");
        } else {
            x.type = "password";
            icon.classList.replace("bi-eye-slash", "bi-eye");
        }
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
