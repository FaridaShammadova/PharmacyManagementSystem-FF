@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Şifrəni Dəyiş";
    Layout = null;
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PharmaSoft - Şifrəni Dəyiş</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
            :root {
                --primary-green: #0f766e;
                --hover-green: #115e59;
                --light-green: #f0fdf4;
            }

            body {
                background: linear-gradient(135deg, #f0fdf4 0%, #f8fafc 100%);
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .card-box {
                width: 100%;
                max-width: 440px;
                padding: 2.5rem;
                border-radius: 20px;
                background: #ffffff;
                box-shadow: 0 15px 35px rgba(15, 118, 110, 0.08);
                border: 1px solid #e2e8f0;
            }

            .logo-area {
                width: 60px;
                height: 60px;
                background-color: var(--light-green);
                color: var(--primary-green);
                border-radius: 16px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 1.5rem auto;
                font-size: 1.8rem;
            }

            .title {
                font-weight: 700;
                font-size: 24px;
                color: #1e293b;
                margin-bottom: 0.5rem;
                text-align: center;
            }

            .subtitle {
                font-size: 0.9rem;
                color: #64748b;
                text-align: center;
                margin-bottom: 2rem;
            }

            .form-label {
                font-weight: 600;
                color: #475569;
                font-size: 0.9rem;
            }

            .input-group-text {
                background-color: #f8fafc;
                border-color: #cbd5e1;
                color: #64748b;
            }

            .toggle-password {
                cursor: pointer;
                border-left: none;
                background-color: #fff;
                transition: color 0.2s;
            }

                .toggle-password:hover {
                    color: var(--primary-green);
                }

            .form-control {
                border-color: #cbd5e1;
                padding: 0.6rem 0.75rem;
            }

                .form-control:focus {
                    border-color: var(--primary-green);
                    box-shadow: 0 0 0 0.25rem rgba(15, 118, 110, 0.15);
                }

                .form-control.has-toggle {
                    border-right: none;
                }

                    .form-control.has-toggle:focus + .toggle-password {
                        border-color: var(--primary-green);
                    }

            .btn-submit {
                background-color: var(--primary-green);
                color: #ffffff;
                font-weight: 600;
                padding: 0.7rem;
                border: none;
                border-radius: 10px;
                transition: all 0.2s ease;
            }

                .btn-submit:hover {
                    background-color: var(--hover-green);
                    color: #ffffff;
                }
    </style>
</head>
<body>

    <div class="card-box">
        <div class="logo-area">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <div class="title">Şifrəni Dəyiş</div>
        <div class="subtitle">Hesabınızın təhlükəsizliyi üçün güclü bir şifrə təyin edin.</div>

        <form asp-action="ChangePassword" method="post">

            <div class="mb-3">
                <label class="form-label">Köhnə şifrə</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input asp-for="OldPassword" type="password" class="form-control has-toggle" placeholder="Mövcud şifrəniz" />
                    <span class="input-group-text toggle-password"><i class="bi bi-eye"></i></span>
                </div>
                <span asp-validation-for="OldPassword" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Yeni şifrə</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                    <input asp-for="NewPassword" type="password" class="form-control has-toggle" placeholder="Minimum 8 simvol" />
                    <span class="input-group-text toggle-password"><i class="bi bi-eye"></i></span>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Yeni şifrə (təkrar)</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                    <input asp-for="ConfirmPassword" type="password" class="form-control has-toggle" placeholder="Yeni şifrəni təsdiqləyin" />
                    <span class="input-group-text toggle-password"><i class="bi bi-eye"></i></span>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            @if (!Html.ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger p-2 rounded mb-3 small" style="background-color: #fef2f2; border: 1px solid #fecaca; color: #dc2626;">
                    <i class="bi bi-exclamation-circle-fill me-2"></i> @Html.ValidationSummary(true, "")
                </div>
            }

            <button type="submit" class="btn btn-submit w-100 shadow-sm">
                <i class="bi bi-check2-circle me-1"></i> Şifrəni yenilə
            </button>

        </form>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <script>
        $(document).ready(function () {
        $('.toggle-password').click(function () {
        var input = $(this).siblings('input');
        var icon = $(this).find('i');

        if (input.attr('type') === 'password') {
        input.attr('type', 'text');
        icon.removeClass('bi-eye').addClass('bi-eye-slash');
        } else {
        input.attr('type', 'password');
        icon.removeClass('bi-eye-slash').addClass('bi-eye');
        }
        });
        });
    </script>
</body>
</html>